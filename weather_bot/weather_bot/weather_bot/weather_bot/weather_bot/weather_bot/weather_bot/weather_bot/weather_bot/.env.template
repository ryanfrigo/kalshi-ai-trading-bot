# ============================================================
# Clawdbot Weather Trader - Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- Kalshi API credentials ---
# Get from: https://kalshi.com/account/api
# Your API Key ID (shown in dashboard):
KALSHI_API_KEY_ID=your-api-key-id-here

# Path to your RSA private key PEM file
# (downloaded when you created the API key):
KALSHI_PRIVATE_KEY_PATH=kalshi.pem

# --- Strategy (override config.py defaults here) ---
# PAPER_TRADE=true    # true = paper only, false = live (dangerous!)
# ENTRY_THRESHOLD=0.15
# EXIT_MULTIPLIER=3.0
# MAX_POSITION_USD=2.00
# SCAN_INTERVAL_SEC=120

# NOAA weather API is FREE and needs no key.
# https://api.weather.gov is used automatically.